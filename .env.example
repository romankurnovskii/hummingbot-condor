# ── Telegram Bot Configuration ────────────────────────
# Create a bot via BotFather: https://t.me/BotFather
TELEGRAM_TOKEN=

# Your Telegram User ID. Find it via: https://t.me/userinfobot
ADMIN_USER_ID=

# ── Hummingbot API Settings ─────────────────────────
DEPLOY_HUMMINGBOT_API=false

# ── Web Dashboard (Optional) ─────────────────────────
# Full public URL for the dashboard (include port if needed)
# Used for Telegram /web links and as the server bind port
# Examples: http://myserver.com:8088, https://dashboard.example.com
# WEB_URL=http://localhost:8088

# ── LLM Providers & API Keys ──────────────────────────
# OpenRouter API Key for AI Strategy/Trading Agents
# Get it from: https://openrouter.ai/
OPENROUTER_API_KEY=

# OpenAI API Key (optional / alternative)
# Get it from: https://platform.openai.com/
OPENAI_API_KEY=

# Default local model configuration
CONDOR_DEFAULT_LOCAL_MODEL=
